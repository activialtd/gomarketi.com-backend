# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.env
.env.heroku

# ── Cryptographic keys — NEVER commit ────────────────────────────────────────
keys/
*.pem
*.p8
*.p12

# ── Go build artifacts ────────────────────────────────────────────────────────
bin/
# Ignore compiled binaries named "server" at repo root or one level deep,
# but NOT cmd/server source directories (which are Go package entry points)
/server
scripts/migrate/migrate
*.test
coverage.out
coverage.html

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
._*
.AppleDouble
.LSOverride

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# ── Frontend build output ─────────────────────────────────────────────────────
.next/
out/
dist/
build/
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Terraform ─────────────────────────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
.terraform.lock.hcl
.vercel
