# ── Environment / secrets — ALL .env variations blocked ──────────────────────
.env
.env.*
*.env
*.env.*
.env.local
.env.development
.env.production
.env.staging
.env.test
.env.*.local
.env.heroku
.env.railway
.env.railway.*
# Allow only the safe template (no real values)
!.env.railway.template
!.env.example
!.env.sample

# ── Cryptographic keys — NEVER commit ────────────────────────────────────────
keys/
*.pem
*.p8
*.p12

# ── Go build artifacts ────────────────────────────────────────────────────────
bin/
# Ignore compiled binaries named "server" at repo root or one level deep,
# but NOT cmd/server source directories (which are Go package entry points)
/server
services/gateway/server
scripts/migrate/migrate
*.test
coverage.out
coverage.html

# ── Local-only scripts with embedded credentials — never commit ──────────────
scripts/seed-cobi/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
._*
.AppleDouble
.LSOverride

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# ── Frontend build output ─────────────────────────────────────────────────────
.next/
out/
dist/
build/
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Terraform ─────────────────────────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
*.tfvars
!*.tfvars.example
# infrastructure/terraform/environments/*.tfvars hold only non-secret
# metadata (environment name, region, CLI profile) — safe and necessary to
# commit for reproducibility. Real secrets live in SSM Parameter Store.
!infrastructure/terraform/environments/*.tfvars
.vercel

# ── Railway env files — contain real secrets, never commit ────────────────────
.env.railway
.env.railway.staging
.env.railway.production
