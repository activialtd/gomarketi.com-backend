# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Neon connection string — sslmode=require is mandatory for Neon.
# For local Docker postgres use:
#   postgresql://gomarketi:localpassword@localhost:5432/gomarketi_dev?sslmode=disable
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Used only by the docker-compose postgres service (local fallback).
POSTGRES_USER=gomarketi
POSTGRES_PASSWORD=localpassword
POSTGRES_DB=gomarketi_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
# From host machine, connect on the EXTERNAL listener (port 9094).
# Inside Docker network, services use kafka:9092.
KAFKA_BROKERS=localhost:9094

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate: make gen-keys
# NEVER commit the .pem files or their raw contents.
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TTL_SECONDS=900       # 15 minutes
JWT_REFRESH_TTL_SECONDS=2592000  # 30 days

# ── AES-256-GCM Encryption ────────────────────────────────────────────────────
# 32 random bytes, hex-encoded (64 hex chars).
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_hex_chars_from_openssl_rand_hex_32

# ── Email — Mailgun (primary) ─────────────────────────────────────────────────
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=GoMarket <noreply@gomarketi.com>

# ── Email — AWS SES (fallback) ────────────────────────────────────────────────
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM=GoMarket <noreply@gomarketi.com>

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Apple OAuth ───────────────────────────────────────────────────────────────
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_BUNDLE_ID=com.activia.gomarket
# Path to the .p8 key file downloaded from Apple Developer portal.
APPLE_PRIVATE_KEY_PATH=./keys/apple_auth_key.p8

# ── ngrok (local webhook testing) ────────────────────────────────────────────
NGROK_AUTHTOKEN=
