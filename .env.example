# Shared across all services — copy to .env and fill in real values
ENVIRONMENT=development

# PostgreSQL (local docker-compose)
POSTGRES_USER=gomarketi
POSTGRES_PASSWORD=localpassword
POSTGRES_DB=gomarketi_dev

# Or use a hosted DB (Neon, Supabase, RDS)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Auth
JWT_SECRET=your_local_development_secret_key

# ngrok — get from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken
