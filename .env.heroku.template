# ─────────────────────────────────────────────────────────────────────────────
# GoMarket Heroku config — copy this to .env.heroku and fill in every value.
# .env.heroku is git-ignored; never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Heroku app names (change these to whatever you called the apps) ───────────
APP_AUTH=gomarket-auth
APP_IDENTITY=gomarket-identity
APP_STOREFRONT=gomarket-storefront
APP_CATALOGUE=gomarket-catalogue
APP_ORDERS=gomarket-orders
APP_GATEWAY=gomarket-gateway

# ── Shared ────────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (same for all services)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Comma-separated list of allowed CORS origins (your Vercel frontend URL)
ALLOWED_ORIGINS=https://your-app.vercel.app

ENV=production

# ── JWT keys (base64-encoded PEM) ─────────────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   base64 -i private.pem | tr -d '\n'   → paste below as JWT_PRIVATE_KEY_B64
#   base64 -i public.pem  | tr -d '\n'   → paste below as JWT_PUBLIC_KEY_B64
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=

# ── Auth service ──────────────────────────────────────────────────────────────
# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=GoMarket <your@gmail.com>

# Google OAuth — from Google Cloud Console
GOOGLE_CLIENT_ID=

# Apple Sign-In — your app's bundle ID
APPLE_BUNDLE_ID=
