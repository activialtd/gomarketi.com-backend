# ─────────────────────────────────────────────────────────────────────────────
# GoMarketi Railway config — copy to .env.railway and fill in every value.
# .env.railway is git-ignored; never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# ── Railway service names (must match what you named them in the dashboard) ───
SVC_AUTH=gomarketi-auth
SVC_IDENTITY=gomarketi-identity
SVC_STOREFRONT=gomarketi-storefront
SVC_CATALOGUE=gomarketi-catalogue
SVC_ORDERS=gomarketi-orders
SVC_GATEWAY=gomarketi-gateway

# ── Shared ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://neondb_owner:...@.../neondb?sslmode=require
ALLOWED_ORIGINS=https://gomarketi.com,https://www.gomarketi.com
ENV=production

# ── JWT keys (base64-encoded PEM — run: base64 -i keys/private.pem | tr -d '\n')
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=

# ── Auth service ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=GoMarketi <your@gmail.com>
GOOGLE_CLIENT_ID=
APPLE_BUNDLE_ID=
